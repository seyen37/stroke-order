# =====================================================================
# stroke-order .gitignore
# =====================================================================

# --- Python -----------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg
build/
dist/
.eggs/
sdist/
wheels/
share/python-wheels/

# Virtual environments
venv/
env/
ENV/
.venv/
.env/

# --- Tests / coverage -------------------------------------------------
.pytest_cache/
.tox/
.nox/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.cover
.hypothesis/

# --- Type checkers ----------------------------------------------------
.mypy_cache/
.ruff_cache/
.pyre/
.pytype/

# --- Secrets / environment variables ----------------------------------
# NEVER commit these — they contain SMTP credentials + auth secrets
.env
.env.local
.env.*.local
*.pem
*.key

# --- Local runtime data ----------------------------------------------
# Generated / cached at runtime, not source
data/g0v_cache/*.json
!data/g0v_cache/.gitkeep
.stroke-order/
.fonts/                 # render_fetch_fonts.sh dest path (Render build artifact, never committed — ~280 MB of TTFs)
gallery.db
gallery.db-journal
*.db
*.db-journal
uploads/

# --- Editor / IDE -----------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# --- Cowork / agent infrastructure (do NOT commit) --------------------
# These are scratch / config from the development environment, not part
# of the project itself.
.auto-memory/
.claude/
.remote-plugins/

# --- Build artefacts --------------------------------------------------
docs/_build/
docs/site/

# --- OS / archive -----------------------------------------------------
*.zip
*.tar
*.tar.gz
*.tgz

# === 根目錄的測試 / 範例輸出（不該進版本控制）===
/*.png
/*.svg
/*.gcode
/*.gif
/*.odp
/*.zip
/*.tar
# 注意：不排除 *.json — pyproject 之類的 .json 可能有用
# 但根目錄的範例 *.json 列出來：
/sample*.json
/test*.json
/[0-9][a-z]_*.json
/[0-9][a-z]_*.gcode

# === 補強：根目錄所有 .json 排除（測試輸出 / 字符 IR 範例）===
/*.json

# === 資料源 cache 整個資料夾排除（runtime 自動產生）===
/data/g0v_cache/
/data/kanjivg_cache/
/data/mmh_cache/
